local player = Players.LocalPlayer

Section:NewKeybind("Toggle UI", "open/close", Enum.KeyCode.B, function()
    Library:ToggleUI()
end)

local farmTIME = 1
local Enabled = false

local Players = game:GetService("Players")
local player = Players.LocalPlayer

local Part
local Connection
local charConn

local runId = 0

Section:NewSlider("delay in teleports", "soso", 10, 1, function(timeFARM)
    farmTIME = timeFARM
end)

Section:NewToggle("auto farm TP", "", function(state)
    Enabled = state

    runId += 1
    local myId = runId

    -- ❌ OFF
    if not state then

        if Connection then
            Connection:Disconnect()
            Connection = nil
        end

        if Part then
            Part:Destroy()
            Part = nil
        end

        if charConn then
            charConn:Disconnect()
            charConn = nil
        end

        return
    end

    -- ✅ AIRWALK (ОСТАВИЛ КАК ТЫ СКАЗАЛ)
    if Part then
        Part:Destroy()
    end

    Part = Instance.new("Part")
    Part.Size = Vector3.new(4,1,4)
    Part.Anchored = true
    Part.CanCollide = true
    Part.Parent = workspace

    Connection = game:GetService("RunService").Heartbeat:Connect(function()
        local Character = player.Character
        local Root = Character and Character:FindFirstChild("HumanoidRootPart")

        if Root and Part then
            Part.Position = Root.Position + Vector3.new(0,-3.5,0)
        end
    end)

    -- 🔁 TELEPORT (RESPAWN-SAFE + RESET GATE)
    local function tp()
        local Character = player.Character or player.CharacterAdded:Wait()
        local Root = Character:WaitForChild("HumanoidRootPart")

        local function step(cf)
            if not Enabled or runId ~= myId then return false end
            Root.CFrame = cf
            task.wait(farmTIME)
            return true
        end

        if not step(CFrame.new(-105.167564,113.341957,1368.97583)) then return end
        if not step(CFrame.new(-90.1123886,113.342079,2142.78418)) then return end
        if not step(CFrame.new(75.1767349,113.342064,2914.53857)) then return end
        if not step(CFrame.new(-110.502899,115.149529,3678.08765)) then return end
        if not step(CFrame.new(-113.162552,115.149529,4449.93994)) then return end
        if not step(CFrame.new(-115.828888,115.149529,5222.73584)) then return end
        if not step(CFrame.new(-118.45929,115.149529,5985.1167)) then return end
        if not step(CFrame.new(-121.168747,115.149529,6770.41064)) then return end
        if not step(CFrame.new(-126.530991,75.1733704,7531.75)) then return end
        if not step(CFrame.new(-90.3094559,77.1855392,8295.91406)) then return end
        if not step(CFrame.new(-56.0303154,-359.162079,9487.84277)) then return end
    end

    -- 🔁 LOOP (СТАРТ ТОЛЬКО ПОСЛЕ RESPAWN)
    task.spawn(function()
        while Enabled and runId == myId do

            tp()

            -- 💀 ВАЖНО: ждём РЕСЕТ ПЕРЕД СЛЕДУЮЩИМ ЦИКЛОМ
            if not Enabled or runId ~= myId then return end
            player.CharacterAdded:Wait()

        end
    end)

    -- 🔁 safety respawn handler
    charConn = player.CharacterAdded:Connect(function()
        if not Enabled or runId ~= myId then return end
        task.wait(0.1)
    end)

end)

