local function SitOnBlobman()
    local plr = game.Players.LocalPlayer
    local char = plr.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")

    if not hrp or not hum then
        return false
    end

    local folderName = plr.Name .. "SpawnedInToys"
    local folder = workspace:FindFirstChild(folderName)

    local chosenBlob = nil

    print("Ищу Blobman...")

    if folder then
        for _, obj in ipairs(folder:GetChildren()) do
            if obj.Name == "CreatureBlobman" then
                local seat = obj:FindFirstChild("VehicleSeat")

                if seat then
                    chosenBlob = obj
                    print("Найден:", chosenBlob)
                    break
                end
            end
        end
    end

    if not chosenBlob then
        print("Спавню Blobman...")

        spavinBlobman()

        local t = tick()

        repeat
            task.wait()

            folder = workspace:FindFirstChild(folderName)

            if folder then
                chosenBlob = folder:FindFirstChild("CreatureBlobman")
            end

        until chosenBlob or tick() - t > 5
    end

    if not chosenBlob then
        warn("Blobman не найден")
        return false
    end

    local seat = chosenBlob:FindFirstChild("VehicleSeat")

    if not seat then
        warn("VehicleSeat не найден")
        return false
    end

    print("Пытаюсь сесть...")

    local t = tick()

    repeat
        hrp.CFrame = seat.CFrame + Vector3.new(0, 1, 0)
        seat:Sit(hum)
        task.wait()

    until hum.SeatPart == seat or tick() - t > 5

    print("Сел:", hum.SeatPart == seat)

    return hum.SeatPart == seat
end

