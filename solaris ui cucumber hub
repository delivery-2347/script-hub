gametab:CreateToggle({
    Name = "Pallet",
    Default = false,
    Flag = "Pallet",
    Callback = function(State)
        Pallet = State

        if not State then
            return
        end

        task.spawn(function()
            local folder = Workspace:FindFirstChild(LocalPlayer.Name .. "SpawnedInToys")
            if not folder then return end

            local targetName = "PalletLightBrown"
            local done = {}

            local function paintSmooth(part)
                if not part or not part:IsA("BasePart") then
                    return
                end

                part.Material = XMATERIYAL

                TweenService:Create(
                    part,
                    TweenInfo.new(1, Enum.EasingStyle.Linear),
                    {
                        Color = SVETPOLETKA
                    }
                ):Play()
            end

            local function apply(model)
                if done[model] then return end
                if #model:GetChildren() < 15 then return end

                done[model] = true

                local targets = {
                    model:FindFirstChild("Main"),
                    model:FindFirstChild("Part"),
                    model:GetChildren()[10],
                    model:GetChildren()[2],
                    model:GetChildren()[3],
                    model:GetChildren()[15],
                    model:GetChildren()[14],
                    model:GetChildren()[13],
                    model:GetChildren()[12],
                    model:GetChildren()[11],
                    model:GetChildren()[4],
                    model:GetChildren()[9],
                    model:GetChildren()[8],
                    model:GetChildren()[7],
                    model:GetChildren()[6],
                    model:GetChildren()[5],
                }

                for _,obj in ipairs(targets) do
                    if obj and obj:IsA("BasePart") then
                        paintSmooth(obj)
                    end
                end
            end

            while Pallet do
                for _,v in ipairs(folder:GetChildren()) do
                    if v.Name == targetName then
                        apply(v)
                    end
                end
                task.wait(0.2)
            end
        end)
    end
})

